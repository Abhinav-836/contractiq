# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ContractIQ
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./contractiq.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/contractiq

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Supported: openai | ollama | gemini | mock
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local or cloud)
# For local: http://localhost:11434
# For cloud: https://api.ollama.com/v1 (or your cloud endpoint)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_API_KEY=your-ollama-cloud-api-key  # Only needed for cloud
OLLAMA_IS_CLOUD=false  # Set to true for cloud endpoints

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Redis (optional - for Celery workers) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0